matrix:
  include:
  - language: perl
    name: Compatibility Test (Perl 5.30)
    perl: 5.3
    install:
    - "./install.sh"
    script:
    - "./scan.sh"
  - language: perl
    name: Compatibility Test (Perl 5.32)
    perl: 5.32
    install:
    - "./install.sh"
    script:
    - "./scan.sh"
  - language: perl
    name: Compatibility Test (Perl 5.33)
    perl: 5.33
    install:
    - "./install.sh"
    script:
    - "./scan.sh"
  - language: ruby
    name: YAML Linting (rvm 3.0)
    rvm: 3.0
    before_install:
    - git clone https://github.com/CICDToolbox/yaml-lint
    install:
    - "./yaml-lint/install.sh"
    script:
    - "./yaml-lint/scan.sh"
  - language: bash
    name: Shellcheck (Bash)
    os: linux
    arch: arm64-graviton2
    before_install:
    - git clone https://github.com/CICDToolbox/shellcheck
    install:
    - "./shellcheck/install.sh"
    script:
    - "./shellcheck/scan.sh"
  - language: ruby
    name: Link Checking (rvm 3.0)
    rvm: 3.0
    env:
    - WHITELIST="https://img.shields.io"
    - EXCLUDE_FILES="CHANGELOG.md"
    before_install:
    - git clone https://github.com/CICDToolbox/awesomebot
    install:
    - "./awesomebot/install.sh"
    script:
    - "./awesomebot/scan.sh"
notifications:
  email: false
  slack:
    secure: 
